# LINE Bot Configuration
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# AI provider selector: openrouter or groq
AI_PROVIDER=groq

# OpenRouter AI Configuration (Primary)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-oss-120b
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=line-bot-ai

# Groq AI Configuration
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=openai/gpt-oss-120b

# Pollinations AI (Optional - for image generation)
POLLINATIONS_API_KEY=your_pollinations_api_key
POLLINATIONS_MODEL=flux

# Google Search (Optional)
GOOGLE_API_KEY=your_google_api_key
GOOGLE_CX=your_custom_search_engine_id

# Speechify TTS (Optional)
SPEECHIFY_API_KEY=your_speechify_api_key

# Cloudinary (Optional - for audio storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google Cloud Storage (Optional - for audio storage)
# Note: GCS_CREDENTIALS should be a JSON string
GCS_CREDENTIALS={"type":"service_account","project_id":"your_project"}
GCS_BUCKET_NAME=your_bucket_name

# Server Configuration
PORT=3000
